APP_ENV=local
MAX_UPLOAD_MB=20
UPLOAD_DIR=data/uploads
RESULT_DIR=data/results

# Storage: local or s3
STORAGE_BACKEND=local
S3_BUCKET=
AWS_REGION=us-east-1

# LLM: offline, openai, or anthropic
LLM_PROVIDER=offline
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Layout model
LAYOUTLM_ENABLED=false
LAYOUTLM_MODEL=microsoft/layoutlmv3-base

# Risk model
RISK_MODEL_PATH=models/risk_classifier.pt

